[fs-uae]
data_dir = configs/fs-uae-data
amiga_model = A1200
kickstart_file = roms/aros/aros-rom.bin
kickstart_ext_file = roms/aros/aros-ext.bin

floppy_drive_0 = work/kickstart-deps/patches/enemy1-boot-split/ENEMY1_V2_DE_A.intro-only.adf
floppy_drive_1 = assets/adf/ENEMY1_V2_DE_B.adf

chip_memory = 2048
slow_memory = 0
fast_memory = 2048
floppy_drive_speed = 0
floppy_drive_volume = 0
floppy_drive_volume_empty = 0
floppy_drive_0_sounds = off
floppy_drive_1_sounds = off
writable_floppy_images = 0

joystick_port_0 = mouse
joystick_port_0_mode = mouse
joystick_port_1 = keyboard
joystick_port_1_mode = joystick
keyboard_key_space = action_quit
keyboard_key_escape = action_quit
keyboard_key_return = action_quit
joystick_port_1_primary = action_quit
automatic_input_grab = 1
initial_input_grab = 1
keyboard_input_grab = 1
full_keyboard = 0
keyboard_key_h = action_key_help

video_sync = 0
cursor = auto
zoom = auto

screenshots_output_dir = output/screenshots
screenshots_output_prefix = tempestreborn_intro_de_a1200_
state_dir = output/states
logs_dir = output/logs
save_state_compression = 0

log_disk = 1
log_a = 1
fullscreen = 0
window_width = 960
window_height = 720
uaelogfile = output/logs/graphics_filter_scale4xhq.log
texture_filter = nearest
smoothing = 0
shader = scale4xhq
